{
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/ipinfo/main/json-structure/ipinfo-me-response-structure.json",
  "name": "MeResponse",
  "description": "MeResponse schema from IPinfo API",
  "type": "object",
  "properties": {
    "token": {
      "type": "string"
    },
    "requests": {
      "type": "object",
      "properties": {
        "day": {
          "type": "int32"
        },
        "month": {
